{
  "name": "nomad-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "NOMAD monorepo workspace",
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/shared"
  ],
  "scripts": {
    "dev": "node scripts/dev-local.js",
    "dev:web": "npm run dev --prefix apps/web",
    "dev:api": "npm run dev --prefix apps/api",
    "db:check": "npm run db:check --prefix apps/api",
    "build:web": "npm run build --prefix apps/web",
    "build:api": "npm run build --prefix apps/api"
  }
}
