VITE_API_BASE_URL=http://localhost:5000
VITE_API_FALLBACK=false

# Founder-only local dashboard
VITE_ENABLE_FOUNDER_DASHBOARD=false
VITE_FOUNDER_DASHBOARD_PATH=/founder/local
VITE_FOUNDER_ADMIN_KEY=change-me-local-admin-key

# Waitlist-first launch mode
VITE_ENABLE_PUBLIC_AUTH_ROUTES=false
VITE_ENABLE_APP_ROUTES=false

# Keep app routes open without auth while editing dashboard flows
VITE_BYPASS_APP_AUTH_GUARD=false

# Optional dev session ribbon in app shell
VITE_DEV_USER_BANNER=false
