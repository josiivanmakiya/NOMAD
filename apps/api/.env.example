PORT=5000
# Atlas preferred:
MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster-host>/NOMAD?retryWrites=true&w=majority&appName=NOMAD
# Local fallback:
# MONGO_URI=mongodb://127.0.0.1:27017/NOMAD

# Founder/admin local access
ADMIN_API_KEY=change-me-local-admin-key
AUTH_BYPASS=false

# App behavior
NODE_ENV=development
ALLOW_MOCK_FUNDING=false
ENABLE_PAYOUTS=false
RESEND_API_KEY=change-me-resend-api-key
RECURRING_CHARGE_FEE_MINOR=0
RESET_DB=false

# Paystack
PAYSTACK_PUBLIC_KEY=pk_test_change_me
PAYSTACK_SECRET_KEY=sk_test_change_me

# AI provider (Nomad Insight)
NOMAD_AI_API_KEY=change-me-ai-key
OPENAI_API_KEY=change-me-openai-key
NOMAD_AI_URL=https://api.openai.com/v1/chat/completions
NOMAD_AI_MODEL=gpt-4o-mini
NOMAD_AI_MAX_TOKENS=220

# Redis and API protection
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300

# Frontend origin for CORS
CORS_ORIGIN=http://localhost:5173
